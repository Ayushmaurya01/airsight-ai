# 1. Firebase Credentials
# Copy these from the Web App setup inside Firebase Console Settings -> General -> Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-app-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-app-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-app-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# 2. Gemini AI API Settings
# Get your key from Google AI Studio (https://aistudio.google.com/)
NEXT_PUBLIC_GEMINI_API_KEY=AIzaSy...
